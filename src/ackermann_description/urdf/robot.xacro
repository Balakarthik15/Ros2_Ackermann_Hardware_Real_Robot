<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="maverick_quantum_xt">

    <!-- ================================ -->
    <!-- ROBOT PROPERTIES -->
    <!-- ================================ -->
    <xacro:property name="body_mass" value="1.58" />
    <xacro:property name="body_length" value="0.475" />
    <xacro:property name="body_width" value="0.21" />
    <xacro:property name="body_height" value="0.160" />

    <xacro:property name="wheelbase" value="0.285" />
    <xacro:property name="track_width" value="0.280" />
    
    <xacro:property name="wheel_radius" value="0.055" />
    <xacro:property name="wheel_thickness" value="0.070" />
    <xacro:property name="wheel_mass" value="0.12" />
    <xacro:property name="steering_mass" value="0.02" />

    <!-- max steering = 45 deg -->
    <xacro:property name="max_steering_angle" value="${pi/4}" />

    <xacro:property name="lidar_radius" value="0.035" />
    <xacro:property name="lidar_height" value="0.055" />
    <xacro:property name="lidar_mass" value="0.05" />

    <!-- Derived properties -->
    <xacro:property name="half_body_length" value="${body_length / 2}" />
    <xacro:property name="half_body_height" value="${body_height / 2}" />

    <xacro:property name="half_track_width" value="${track_width / 2}" />
    <xacro:property name="front_axle_offset" value="${wheelbase / 2}" />
    <xacro:property name="rear_axle_offset" value="${-wheelbase / 2}" />


    <!-- ================================ -->
    <!-- BASE FOOTPRINT -->
    <!-- ================================ -->
    <link name="base_footprint">
    </link>

    <!-- ================================ -->
    <!-- BASE LINK -->
    <!-- ================================ -->
    <link name="base_link">
    </link>
    
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
    </joint>

    <!-- ================================ -->
    <!-- CHASSIS LINK -->
    <!-- ================================ -->
    <link name="chassis_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
            <mass value="${body_mass}" />
            <inertia
                ixx="${body_mass/12 * (body_width*body_width + body_height*body_height)}"
                ixy="0" ixz="0"
                iyy="${body_mass/12 * (body_length*body_length + body_height*body_height)}"
                iyz="0"
                izz="${body_mass/12 * (body_length*body_length + body_width*body_width)}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}" />
            </geometry>
            <material name="red">
                <color rgba="0.25 0.25 0.25 1.0"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}" />
            </geometry>
        </collision>
    </link>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link" />
        <child link="chassis_link" />
        <!-- chassis center height so wheel centers end up at wheel_radius above ground -->
        <origin xyz=" 0.0 0.0 ${wheel_radius + body_height/2}" rpy="0 0 0" />
    </joint>

    <!-- ================================ -->
    <!-- FRONT LEFT STEERING LINK -->
    <!-- ================================ -->
    <link name="fr_left_steer_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${steering_mass}" />
            <inertia
                ixx="${steering_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${steering_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${steering_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <!-- Simple visual so it shows in RViz/Gazebo -->
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="0.01" length="0.03"/>
            </geometry>
            <material name="steer_red">
                <color rgba="0.8 0.1 0.1 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="0.01" length="0.03"/>
            </geometry>
        </collision>
        
    </link>

    <joint name="fr_left_steer_joint" type="revolute">
        <parent link="chassis_link" />
        <child link="fr_left_steer_link" />
        <origin xyz="${front_axle_offset} ${half_track_width} ${-body_height/2}" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit upper="${max_steering_angle}" lower="${-max_steering_angle}" effort="10.0" velocity="2.0" />
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- ================================ -->
    <!-- FRONT LEFT WHEEL -->
    <!-- ================================ -->
    <link name="fr_left_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${wheel_mass}" />
            <inertia
                ixx="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${wheel_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
            <material name="wheel_dark">
                <color rgba="0.35 0.35 0.35 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
        </collision>
    </link>

    <joint name="fr_left_wheel_joint" type="continuous">
        <parent link="fr_left_steer_link" />
        <child link="fr_left_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics friction="0.1" damping="0.1" />
        <limit lower="-3.14159" upper="3.14159" effort="70" velocity="50" />
    </joint>

    <!-- ================================ -->
    <!-- FRONT RIGHT STEERING LINK -->
    <!-- ================================ -->
    <link name="fr_right_steer_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${steering_mass}" />
            <inertia
                ixx="${steering_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${steering_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${steering_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <!-- Simple visual so it shows in RViz/Gazebo -->
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="0.01" length="0.03"/>
            </geometry>
            <material name="steer_red2">
                <color rgba="0.8 0.1 0.1 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="0.01" length="0.03"/>
            </geometry>
        </collision>

    </link>

    <joint name="fr_right_steer_joint" type="revolute">
        <parent link="chassis_link" />
        <child link="fr_right_steer_link" />
        <origin xyz="${front_axle_offset} ${-half_track_width} ${-body_height/2}" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit upper="${max_steering_angle}" lower="${-max_steering_angle}" effort="10.0" velocity="2.0" />
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- ================================ -->
    <!-- FRONT RIGHT WHEEL -->
    <!-- ================================ -->
    <link name="fr_right_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${wheel_mass}" />
            <inertia
                ixx="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${wheel_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
            <material name="wheel_dark2">
                <color rgba="0.35 0.35 0.35 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
        </collision>
    </link>

    <joint name="fr_right_wheel_joint" type="continuous">
        <parent link="fr_right_steer_link" />
        <child link="fr_right_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics friction="0.1" damping="0.1" />
        <limit lower="-3.14159" upper="3.14159" effort="70" velocity="50" />
    </joint>

    <!-- ================================ -->
    <!-- REAR LEFT WHEEL -->
    <!-- ================================ -->
    <link name="re_left_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${wheel_mass}" />
            <inertia
                ixx="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${wheel_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
            <material name="wheel_dark3">
                <color rgba="0.35 0.35 0.35 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
        </collision>
    </link>

    <joint name="re_left_wheel_joint" type="continuous">
        <parent link="chassis_link" />
        <child link="re_left_wheel_link" />
        <origin xyz="${rear_axle_offset} ${half_track_width} ${-body_height/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics friction="0.1" damping="0.1" />
        <limit lower="-3.14159" upper="3.14159" effort="70" velocity="50" />
    </joint>

    <!-- ================================ -->
    <!-- REAR RIGHT WHEEL -->
    <!-- ================================ -->
    <link name="re_right_wheel_link">
        <inertial>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <mass value="${wheel_mass}" />
            <inertia
                ixx="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                ixy="0" ixz="0"
                iyy="${wheel_mass/12*(3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
                iyz="0"
                izz="${wheel_mass/2 * wheel_radius*wheel_radius}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
            <material name="wheel_dark4">
                <color rgba="0.35 0.35 0.35 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
            </geometry>
        </collision>
    </link>

    <joint name="re_right_wheel_joint" type="continuous">
        <parent link="chassis_link" />
        <child link="re_right_wheel_link" />
        <origin xyz="${rear_axle_offset} ${-half_track_width} ${-body_height/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics friction="0.1" damping="0.1" />
        <limit lower="-3.14159" upper="3.14159" effort="70" velocity="50" />
    </joint>

    <!-- ================================ -->
    <!-- LIDAR LINK -->
    <!-- ================================ -->
    <link name="bot_ackermann/base_footprint/gpu_lidar">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="${lidar_mass}" />
            <inertia
                ixx="${lidar_mass/12*(3*lidar_radius*lidar_radius + lidar_height*lidar_height)}"
                ixy="0" ixz="0"
                iyy="${lidar_mass/12*(3*lidar_radius*lidar_radius + lidar_height*lidar_height)}"
                iyz="0"
                izz="${lidar_mass/2 * lidar_radius*lidar_radius}" />
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${lidar_radius}" length="${lidar_height}" />
            </geometry>
            <material name="lidar_black">
                <color rgba="0.1 0.1 0.1 1" />
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${lidar_radius}" length="${lidar_height}" />
            </geometry>
        </collision>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="chassis_link" />
        <child link="bot_ackermann/base_footprint/gpu_lidar" />
        <!-- LiDAR at front edge + its radius, sitting on top surface -->
        <origin xyz=" 0.1 0.0 ${body_height/2 + lidar_height/2}" rpy="0 0 0" />
    </joint>
    
    <!-- ================================ -->
    <!-- VIRTUAL STEERING WHEEL -->
    <!-- ================================ -->
    <link name="virtual_steer_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <box size="0.01 0.15 0.075" />
            </geometry>
            <material name="yellow">
                <color rgba="1.0 1.0 0.0 1" />
            </material>
        </visual>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.001" />
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                     iyy="0.0001" iyz="0.0" izz="0.0001" />
        </inertial>
    </link>
    
    <joint name="virtual_steering_wheel_joint" type="revolute">
        <origin xyz="${-body_length/2 + 0.05} 0.0 0.0" rpy="0.0 0.0 0.0" />
        <parent link="chassis_link" />
        <child link="virtual_steer_link" />
        <axis xyz="-1 0 0" />
        <limit lower="-3" upper="3" effort="200" velocity="20" />
    </joint>


    <!-- ================================ -->
    <!-- GAZEBO PLUGIN CONFIGURATIONS -->
    <!-- ================================ -->
    
    <!-- Chassis -->
    <gazebo reference="chassis_link">
        <mu1>0.001</mu1>
        <mu2>0.001</mu2>
        <material>Gazebo/Grey</material>
    </gazebo>
    
    <!-- Steering links
    <gazebo reference="fr_left_steer_link">
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
    
    <gazebo reference="fr_right_steer_link">
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
     -->
    <!-- Front wheels -->
    <gazebo reference="fr_left_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <gazebo reference="fr_right_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <!-- Rear wheels -->
    <gazebo reference="re_left_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <gazebo reference="re_right_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <!-- Virtual steering wheel -->
    <gazebo reference="virtual_steer_link">
        <material>Gazebo/Yellow</material>
    </gazebo>
    
    <!-- LiDAR -->
    <gazebo reference="bot_ackermann/base_footprint/gpu_lidar">
        <sensor type="gpu_lidar" name="gpu_lidar">
            <pose relative_to='bot_ackermann/base_footprint/gpu_lidar'>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <topic>scan</topic>
            <update_rate>10</update_rate>
            <always_on>true</always_on>
            
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                
                <range>
                    <min>0.15</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
                
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
        </sensor>
    </gazebo>


    <!-- ================================ -->
    <!-- JOINT STATE PUBLISHER PLUGIN -->
    <!-- ================================ -->
    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <update_rate>100</update_rate>
            <joint_name>fr_right_steer_joint</joint_name>
            <joint_name>fr_right_wheel_joint</joint_name>
            <joint_name>fr_left_steer_joint</joint_name>
            <joint_name>fr_left_wheel_joint</joint_name>
            <joint_name>re_right_wheel_joint</joint_name>
            <joint_name>re_left_wheel_joint</joint_name>
            <joint_name>virtual_steering_wheel_joint</joint_name>
        </plugin>
    </gazebo>


        <!-- Gazebo Control -->
    <ros2_control name="control" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
            
        <joint name="fr_left_steer_joint">
            <command_interface name="position">
                <!-- <param name="min">${-max_steering_angle}</param>
                <param name="max">${max_steering_angle}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="fr_right_steer_joint">
            <command_interface name="position">
                <!-- <param name="min">${-max_steering_angle}</param>
                <param name="max">${max_steering_angle}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="re_left_wheel_joint">
            <command_interface name="velocity">
                <!-- <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="re_right_wheel_joint">
            <command_interface name="velocity">
                <!-- <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
    </ros2_control>

    

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters> $(find ackermann_gazebo)/config/gz_ros2_control.yaml</parameters>
        
            <ros>
                <remapping>ackermann_steering_controller/tf_odometry:=/tf</remapping>
                <remapping>ackermann_steering_controller/odometry:=/odom</remapping>

            </ros>
        </plugin>
    </gazebo>



    <gazebo>
        <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
  </gazebo>

</robot>






  