    <!-- ================================ -->
    <!-- VIRTUAL STEERING WHEEL -->
    <!-- ================================ -->
    <link name="virtual_steer_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <box size="0.01 0.15 0.075" />
            </geometry>
            <material name="yellow">
                <color rgba="1.0 1.0 0.0 1" />
            </material>
        </visual>
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <mass value="0.001" />
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                     iyy="0.0001" iyz="0.0" izz="0.0001" />
        </inertial>
    </link>
    
    <joint name="virtual_steering_wheel_joint" type="revolute">
        <origin xyz="${-body_length/2 + 0.05} 0.0 0.0" rpy="0.0 0.0 0.0" />
        <parent link="chassis_link" />
        <child link="virtual_steer_link" />
        <axis xyz="-1 0 0" />
        <limit lower="-3" upper="3" effort="200" velocity="20" />
    </joint>


    <!-- ================================ -->
    <!-- GAZEBO PLUGIN CONFIGURATIONS -->
    <!-- ================================ -->
    
    <!-- Chassis -->
    <gazebo reference="chassis_link">
        <mu1>0.001</mu1>
        <mu2>0.001</mu2>
        <material>Gazebo/Grey</material>
    </gazebo>
    
    <!-- Steering links
    <gazebo reference="fr_left_steer_link">
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
    
    <gazebo reference="fr_right_steer_link">
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
        <material>Gazebo/Black</material>
    </gazebo>
     -->
    <!-- Front wheels -->
    <gazebo reference="fr_left_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <gazebo reference="fr_right_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <!-- Rear wheels -->
    <gazebo reference="re_left_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <gazebo reference="re_right_wheel_link">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    
    <!-- Virtual steering wheel -->
    <gazebo reference="virtual_steer_link">
        <material>Gazebo/Yellow</material>
    </gazebo>
    
    <!-- LiDAR -->
    <gazebo reference="bot_ackermann/base_footprint/gpu_lidar">
        <sensor type="gpu_lidar" name="gpu_lidar">
            <pose relative_to='bot_ackermann/base_footprint/gpu_lidar'>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <topic>scan</topic>
            <update_rate>10</update_rate>
            <always_on>true</always_on>
            
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                
                <range>
                    <min>0.15</min>
                    <max>12.0</max>
                    <resolution>0.01</resolution>
                </range>
                
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
        </sensor>
    </gazebo>


    <!-- ================================ -->
    <!-- JOINT STATE PUBLISHER PLUGIN -->
    <!-- ================================ -->
    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <update_rate>100</update_rate>
            <joint_name>fr_right_steer_joint</joint_name>
            <joint_name>fr_right_wheel_joint</joint_name>
            <joint_name>fr_left_steer_joint</joint_name>
            <joint_name>fr_left_wheel_joint</joint_name>
            <joint_name>re_right_wheel_joint</joint_name>
            <joint_name>re_left_wheel_joint</joint_name>
            <joint_name>virtual_steering_wheel_joint</joint_name>
        </plugin>
    </gazebo>


        <!-- Gazebo Control -->
    <ros2_control name="control" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
            
        <joint name="fr_left_steer_joint">
            <command_interface name="position">
                <!-- <param name="min">${-max_steering_angle}</param>
                <param name="max">${max_steering_angle}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="fr_right_steer_joint">
            <command_interface name="position">
                <!-- <param name="min">${-max_steering_angle}</param>
                <param name="max">${max_steering_angle}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="re_left_wheel_joint">
            <command_interface name="velocity">
                <!-- <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="re_right_wheel_joint">
            <command_interface name="velocity">
                <!-- <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param> -->
            </command_interface>

            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
    </ros2_control>
    

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters> $(find ackermann_gazebo)/config/gz_ros2_control.yaml</parameters>
        
            <ros>
                <remapping>ackermann_steering_controller/tf_odometry:=/tf</remapping>
                <remapping>ackermann_steering_controller/odometry:=/odom</remapping>

            </ros>
        </plugin>
    </gazebo>



    <gazebo>
        <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
  </gazebo>